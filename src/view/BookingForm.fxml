<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.BookingFormController"
            fitToWidth="true"
            style="-fx-background-color: rgb(245,246,250);">

    <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 30;">

        <!-- Header -->
        <Label text="📅 Book Your Event"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: rgb(44,62,80);" />

        <!-- Venue Info -->
        <VBox fx:id="venueInfoBox" spacing="10"
              style="-fx-background-color: rgb(236,240,241); -fx-padding: 15; -fx-background-radius: 8;">
            <Label fx:id="venueNameLabel" text="Venue: Loading..."
                   style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="venueDetailsLabel" text="Details loading..." />
            <Label fx:id="venuePriceLabel" text="Price: 0.00/hour"
                   style="-fx-text-fill: rgb(39,174,96); -fx-font-weight: bold;" />
        </VBox>

        <Separator/>

        <!-- Event Details -->
        <VBox spacing="15">
            <Label text="Event Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <GridPane hgap="15" vgap="15">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" prefWidth="130"/>
                    <ColumnConstraints minWidth="300" hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Event Name: *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="eventNameField" promptText="Enter event name" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Event Type: *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="eventTypeCombo" promptText="Select event type" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="300"/>

                <Label text="Event Date: *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="eventDatePicker" promptText="Select date" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="300"/>

                <Label text="Start Time: *" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="startTimeField" promptText="e.g., 09:00" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="End Time: *" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="endTimeField" promptText="e.g., 17:00" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Number of Guests: *" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="numberOfGuestsField" promptText="Enter number of guests" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <Separator/>

        <!-- Contact Information -->
        <VBox spacing="15">
            <Label text="Contact Information" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <GridPane hgap="15" vgap="15">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" prefWidth="130"/>
                    <ColumnConstraints minWidth="300" hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Contact Person: *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="contactPersonField" promptText="Enter contact name" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Contact Phone: *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="contactPhoneField" promptText="Enter phone number" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <Separator/>

        <!-- Special Requests -->
        <VBox spacing="10">
            <Label text="Special Requests (Optional)" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TextArea fx:id="specialRequestsArea" promptText="Enter any special requirements..." prefRowCount="4" wrapText="true"/>
        </VBox>

        <Separator/>

        <!-- Price Display -->
        <HBox spacing="10" alignment="CENTER"
              style="-fx-background-color: rgb(255,243,205); -fx-padding: 15; -fx-background-radius: 8;">
            <Label text="Estimated Total:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label fx:id="totalPriceLabel" text="&#36;0.00"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: rgb(231,76,60);"/>
        </HBox>

        <!-- Buttons -->
        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10;">
            <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel"
                    style="-fx-background-color: rgb(149,165,166); -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 150; -fx-pref-height: 40;"/>

            <Button fx:id="submitButton" text="📅 Confirm Booking" onAction="#handleSubmit"
                    style="-fx-background-color: rgb(231,76,60); -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 40;"/>
        </HBox>

        <Label text="* Required fields"
               style="-fx-text-fill: rgb(231,76,60); -fx-font-size: 12px; -fx-font-style: italic;"/>

    </VBox>
</ScrollPane>
