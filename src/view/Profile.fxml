<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ProfileController"
            fitToWidth="true"
            style="-fx-background: transparent;">
    
    <VBox spacing="20" style="-fx-padding: 20;">

       <!-- Header -->
       <Label fx:id="welcomeLabel" text="👤 My Profile" 
              style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

       <!-- Message Label -->
       <Label fx:id="messageLabel" text="" 
              style="-fx-font-size: 14; -fx-font-weight: bold;" />

       <!-- Profile Information Section -->
       <VBox spacing="15" style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-border-radius: 10;">
          <Label text="📋 Profile Information" 
                 style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

          <!-- Full Name -->
          <VBox spacing="5">
             <Label text="Full Name:" style="-fx-font-weight: bold;" />
             <TextField fx:id="fullNameField" promptText="Enter your full name" 
                        style="-fx-pref-width: 400;" />
          </VBox>

          <!-- Email -->
          <VBox spacing="5">
             <Label text="Email:" style="-fx-font-weight: bold;" />
             <TextField fx:id="emailField" promptText="Enter your email" 
                        style="-fx-pref-width: 400;" />
          </VBox>

          <!-- Phone Number -->
          <VBox spacing="5">
             <Label text="Phone Number:" style="-fx-font-weight: bold;" />
             <TextField fx:id="phoneField" promptText="Enter your phone number" 
                        style="-fx-pref-width: 400;" />
          </VBox>

          <!-- Preferences -->
          <VBox spacing="5">
             <Label text="Preferences:" style="-fx-font-weight: bold;" />
             <TextArea fx:id="preferencesArea" promptText="Enter your preferences (optional)" 
                       prefRowCount="3" wrapText="true" style="-fx-pref-width: 400;" />
          </VBox>

          <!-- Save Profile Button -->
          <HBox spacing="10">
             <Button fx:id="saveProfileButton" text="💾 Save Profile" 
                     onAction="#handleSaveProfile"
                     style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 150; -fx-font-weight: bold;" />
             <Button text="🔄 Reset" onAction="#handleResetForm"
                     style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-pref-width: 100;" />
          </HBox>
       </VBox>

       <!-- Change Password Section -->
       <VBox spacing="15" style="-fx-background-color: #fef5e7; -fx-padding: 20; -fx-border-radius: 10;">
          <Label text="🔒 Change Password" 
                 style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

          <!-- Current Password -->
          <VBox spacing="5">
             <Label text="Current Password:" style="-fx-font-weight: bold;" />
             <PasswordField fx:id="currentPasswordField" 
                            promptText="Enter current password" 
                            style="-fx-pref-width: 400;" />
          </VBox>

          <!-- New Password -->
          <VBox spacing="5">
             <Label text="New Password:" style="-fx-font-weight: bold;" />
             <PasswordField fx:id="newPasswordField" 
                            promptText="Enter new password (min 6 characters)" 
                            style="-fx-pref-width: 400;" />
          </VBox>

          <!-- Confirm Password -->
          <VBox spacing="5">
             <Label text="Confirm New Password:" style="-fx-font-weight: bold;" />
             <PasswordField fx:id="confirmPasswordField" 
                            promptText="Confirm new password" 
                            style="-fx-pref-width: 400;" />
          </VBox>

          <!-- Change Password Button -->
          <Button fx:id="changePasswordButton" text="🔑 Change Password" 
                  onAction="#handleChangePassword"
                  style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-pref-width: 180; -fx-font-weight: bold;" />
       </VBox>

    </VBox>
</ScrollPane>
