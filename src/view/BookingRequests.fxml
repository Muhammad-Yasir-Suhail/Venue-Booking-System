<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.BookingRequestsController"
      spacing="20" style="-fx-padding: 20;">
   
   <Label text="📋 Booking Requests Management" 
          style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
   
   <!-- Filter Section -->
   <VBox spacing="15" style="-fx-background-color: #ecf0f1; -fx-padding: 20; -fx-border-radius: 10;">
      <Label text="Filter Bookings" style="-fx-font-size: 16; -fx-font-weight: bold;" />
      
      <HBox spacing="15" alignment="CENTER_LEFT">
         <Label text="Filter by Status:" />
         <ComboBox fx:id="statusFilterCombo" prefWidth="150" />
         <Button fx:id="refreshButton" text="🔄 Refresh" onAction="#handleRefresh" 
                 style="-fx-background-color: #3498db; -fx-text-fill: white;" />
      </HBox>
   </VBox>
   
   <!-- Results Section -->
   <VBox spacing="15" VBox.vgrow="ALWAYS">
      <Label fx:id="resultsLabel" text="Loading booking requests..." 
             style="-fx-font-size: 14; -fx-font-weight: bold;" />

      <!-- Scrollable Requests List -->
      <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
         <content>
            <VBox fx:id="requestsContainer" spacing="10" />
         </content>
      </ScrollPane>
   </VBox>

</VBox>
