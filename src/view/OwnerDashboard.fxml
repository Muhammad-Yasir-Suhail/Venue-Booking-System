<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.OwnerDashboardController">
    
    <!-- Top Header -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #7fd1b9, #7fd1b9); -fx-padding: 12 20;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Venue Owner Dashboard" 
                       style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />
                <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 14;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" 
                        style="-fx-background-color: #f54748; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </top>
    
    <!-- Left Navigation -->
    <left>
        <VBox spacing="15" style="-fx-background-color: #e0e0e0; -fx-padding: 20; -fx-border-radius: 0 10 10 0;">
            
            <!-- Gradient Nav Buttons with Hover -->
            <Button fx:id="manageVenuesButton" text="🏢 Manage Venues" onAction="#handleManageVenues" 
                    style="-fx-background-color: linear-gradient(to right, #5e60ce, #9b5de5); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" 
                    prefWidth="180" prefHeight="45" />
                    
            <Button text="📋 Booking Requests" onAction="#handleBookingRequests" 
                    style="-fx-background-color: linear-gradient(to right, #5e60ce, #9b5de5); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" 
                    prefWidth="180" prefHeight="45" />
                    
            <Button fx:id="revenueButton" text="💰 Revenue Reports" onAction="#handleRevenueReports" 
                    style="-fx-background-color: linear-gradient(to right, #f08a5d, #f9ed69); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" 
                    prefWidth="180" prefHeight="45" />
                    
            <Button fx:id="ownerProfileButton" text="👤 My Profile" onAction="#handleProfile" 
                    style="-fx-background-color: #6a0572; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" 
                    prefWidth="180" prefHeight="45"/>
        </VBox>
    </left>
    
    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f5f5f5; -fx-border-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 5);">
            <Label text="Welcome to Venue Owner Dashboard! 🏢\nManage your venues and booking requests here." 
                   style="-fx-font-size: 16; -fx-text-alignment: center; -fx-text-fill: #2c3e50;" 
                   alignment="CENTER" />
        </StackPane>
    </center>
    
</BorderPane>
