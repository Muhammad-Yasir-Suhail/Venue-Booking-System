<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" 
           xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controller.ForgotPasswordController"
           style="-fx-background-color: linear-gradient(to bottom right, #667eea 0%, #764ba2 100%);">
    
    <ScrollPane fitToWidth="true" fitToHeight="true"
                style="-fx-background: transparent; -fx-background-color: transparent;"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        
        <VBox alignment="CENTER" spacing="30" style="-fx-padding: 50;">
            
            <!-- Card Container -->
            <VBox alignment="CENTER" spacing="30"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10);"
                  maxWidth="500">
                
                <padding>
                    <Insets top="50" right="50" bottom="50" left="50"/>
                </padding>
                
                <!-- Title Section -->
                <VBox alignment="CENTER" spacing="15">
                    <Label text="Forgot Password" textFill="#2c3e50" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                    <Label text="Enter your email address and we'll send you a reset link" 
                           textFill="#7f8c8d" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 14px;" />
                </VBox>
                
                <!-- Email Input Section -->
                <VBox spacing="10" maxWidth="350">
                    <Label text="Email Address *" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                    <TextField fx:id="emailField" promptText="Enter your registered email"
                               style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 14;" />
                </VBox>
                
                <!-- Send Button -->
                <Button fx:id="sendResetButton" mnemonicParsing="false" onAction="#handleSendReset" 
                        prefHeight="45" prefWidth="220"
                        style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 15px;"
                        text="Send Reset Link" />
                
                <!-- Back to Login Link -->
                <Hyperlink fx:id="backToLoginLink" onAction="#handleBackToLogin" 
                           text="Back to Login" style="-fx-text-fill: #667eea; -fx-font-size: 13px;" />
                
                <!-- Message Label -->
                <Label fx:id="messageLabel" wrapText="true" textAlignment="CENTER" 
                       textFill="#e74c3c" maxWidth="350" style="-fx-font-size: 13px;" />
                
                <!-- Demo Section -->
                <VBox fx:id="demoSection" spacing="8" visible="false" maxWidth="350" 
                      style="-fx-background-color: #ecf0f1; -fx-padding: 12; -fx-background-radius: 10;">
                    <Label text="🔧 Demo Information:" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label fx:id="demoTokenLabel" textFill="#8e44ad" wrapText="true" style="-fx-font-size: 12px;" />
                    <Hyperlink fx:id="demoResetLink" onAction="#handleDemoReset" 
                               text="Click here to test reset process" style="-fx-font-size: 12px;" />
                </VBox>
                
            </VBox>
            
        </VBox>
        
    </ScrollPane>
    
</StackPane>
