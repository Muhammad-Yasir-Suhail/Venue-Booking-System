<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.AdminDashboardController"
      style="-fx-background-color: #f5f7fa;">
   
   <!-- Header -->
   <HBox style="-fx-background-color: linear-gradient(to right, #a1c4fd, #c2e9fb); -fx-padding: 15; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
      <Label fx:id="welcomeLabel" text="Welcome, Administrator!" 
             style="-fx-text-fill: #34495e; -fx-font-size: 20; -fx-font-weight: bold;"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button fx:id="logoutButton" text="🚪 Logout" onAction="#handleLogout" 
              style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"/>
   </HBox>
   
   <!-- Main Content -->
   <HBox VBox.vgrow="ALWAYS">
      
      <!-- Navigation Sidebar -->
      <VBox style="-fx-padding: 20; -fx-min-width: 250; -fx-background-color: #e0e0e0; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
         <VBox spacing="15">
            
            <!-- Gradient Buttons -->
            <Button text="📊 System Overview" onAction="#handleSystemOverview"
                    style="-fx-background-color: linear-gradient(to right, #89f7fe, #66a6ff); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"
                    prefWidth="200" prefHeight="45"/>
            
            <Button text="👥 Manage Users" onAction="#handleManageUsers"
                    style="-fx-background-color: linear-gradient(to right, #43e97b, #38f9d7); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"
                    prefWidth="200" prefHeight="45"/>
            
            <Button text="📋 All Bookings" onAction="#handleAllBookings"
                    style="-fx-background-color: linear-gradient(to right, #fbc2eb, #a18cd1); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"
                    prefWidth="200" prefHeight="45"/>
            
            <Button text="📈 System Reports" onAction="#handleSystemReports"
                    style="-fx-background-color: linear-gradient(to right, #fad0c4, #ffd1ff); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;"
                    prefWidth="200" prefHeight="45"/>
            
            <Region VBox.vgrow="ALWAYS"/>
         </VBox>
      </VBox>
      
      <!-- Content Area -->
      <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" 
                 style="-fx-background-color: #ffffff; -fx-padding: 25; -fx-border-radius: 15; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"/>
   </HBox>

</VBox>
